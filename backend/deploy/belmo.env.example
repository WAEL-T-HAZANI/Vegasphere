# Paste these into Belmo → Environment variables (production).
# Replace placeholder values where noted. Do not commit real secrets to git.

NODE_ENV=production

JWT_SECRET=your-strong-jwt-secret-min-32-chars
# Include the database name in the URI (or set MONGO_DB_NAME separately).
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/Vegasphere?retryWrites=true&w=majority
MONGO_DB_NAME=Vegasphere
MONGO_AUTO_INDEX=1

CORS_ORIGINS=https://vegasphere-chat-app.netlify.app
PUBLIC_APP_URL=https://vegasphere-chat-app.netlify.app
PUBLIC_API_URL=https://vegasphere-41e7.onbelmo.uk

# Do not set REDIS_URL on Belmo free tier.

ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"},{"urls":["turn:openrelay.metered.ca:80","turn:openrelay.metered.ca:443","turn:openrelay.metered.ca:443?transport=tcp"],"username":"openrelayproject","credential":"openrelayproject"}]

# ---- Email (pick ONE approach) -------------------------------------------
#
# Option A — Brevo SMTP (recommended for Belmo: reliable to any inbox)
# Sign up: https://www.brevo.com → SMTP & API → create SMTP key
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your-brevo-login-email
# SMTP_PASS=your-brevo-smtp-key
# SMTP_SECURE=0
# MAIL_FROM=Vegasphere <noreply@yourdomain.com>
#
# Option B — Resend API (best deliverability; verify your domain on Resend)
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=Vegasphere <noreply@yourdomain.com>
#
# Option C — Gmail SMTP (works locally; Belmo cloud IP may be filtered by Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_SECURE=0
# Leave empty to auto-use SMTP_USER (no extra quotes in Belmo UI)
MAIL_FROM=

# Web Push (VAPID) — copy from backend/.env.secrets-backup
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your@gmail.com

# Production: real emails only (no debug tokens in API responses)
EMAIL_VERIFY_DEBUG=0
PASSWORD_RESET_DEBUG=0

# User reports → moderator inbox (defaults to SMTP_USER / wael.t.hazani@gmail.com)
REPORT_ADMIN_EMAIL=wael.t.hazani@gmail.com

# Full AI dictionary (~952 MB) — baked into the image at BUILD time (Coolify/Belmo /app is read-only at runtime).
VEGA_DICT_URL=https://github.com/WAEL-T-HAZANI/Vegasphere/releases/download/vega-dict-v1/vega-dict.db
# Runtime only — do NOT enable at build time (postinstall must download the DB during npm ci).
VEGA_DICT_SKIP_DOWNLOAD=1

# Optional: lower bcrypt cost on small containers
BCRYPT_ROUNDS=10
