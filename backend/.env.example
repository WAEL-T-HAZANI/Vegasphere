NODE_ENV=development
PORT=5500

JWT_SECRET=replace-with-a-strong-local-secret
MONGO_URI=mongodb://localhost:27017/vegasphere
MONGO_AUTO_INDEX=1

CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
PUBLIC_APP_URL=http://localhost:3001
PUBLIC_API_URL=http://localhost:5500

REDIS_URL=redis://127.0.0.1:6379
REDIS_UNREAD_MIRROR=1

# WebRTC calls:
# For a simple live university demo, OpenRelay provides free public TURN.
# For production/commercial use, replace it with your own paid/private TURN.
ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:openrelay.metered.ca:80","username":"openrelayproject","credential":"openrelayproject"},{"urls":"turn:openrelay.metered.ca:443","username":"openrelayproject","credential":"openrelayproject"},{"urls":"turn:openrelay.metered.ca:443?transport=tcp","username":"openrelayproject","credential":"openrelayproject"}]

# Web Push (VAPID): generate with `npx web-push generate-vapid-keys`.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Email. For local dev, debug links can be logged instead of sent.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=0
EMAIL_VERIFY_DEBUG=1
PASSWORD_RESET_DEBUG=1

# Optional S3/R2. Leave blank to use local backend/uploads.
S3_BUCKET=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_PUBLIC_BASE_URL=
