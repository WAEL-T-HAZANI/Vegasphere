# ── Dependencies (any package in the monorepo) ──
node_modules/

# ── Environment (never commit secrets) ──
.env
.env.*
!.env.example

# ── Logs ──
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# ── Build outputs ──
.next/
out/
dist/
build/

# ── TypeScript ──
*.tsbuildinfo

# ── Caches ──
.swc/
.npm/
.eslintcache
.stylelintcache
.parcel-cache
.cache/
.turbo/

# ── Yarn Berry ──
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# ── Backend runtime ──
backend/uploads/

# ── Frontend test artifacts ──
frontend-next/test-results/
frontend-next/playwright-report/
frontend-next/coverage/

# ── Deploy / hosting ──
.vercel/

# ── Coverage (generic) ──
coverage/
*.lcov
.nyc_output

# ── Diagnostics / runtime ──
report.*.json
pids/
*.pid
*.seed
*.pid.lock

# ── Local screenshots / scratch ──
screenshots/
scripts/.dev-logs/

# ── Editor & OS ──
.vscode-test
.tern-port
.idea/
*.swp
.DS_Store
Thumbs.db
